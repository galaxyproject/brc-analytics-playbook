# Nginx Configuration for Multi-Environment Host
# Managed by Ansible - do not edit manually
#
# Routes each domain to its own backend container, optionally serving
# the per-env Next.js static export and static API data files.

# CORS origin whitelist for static API files (shared across envs)
map $http_origin $cors_origin {
    default "";
    "https://www.ncbi.nlm.nih.gov" $http_origin;
    "https://ncbi.nlm.nih.gov" $http_origin;
}

{% for env in brc_environments %}
# ============ {{ env.name | upper }} ============

upstream backend-{{ env.name }} {
    server 127.0.0.1:{{ env.backend_port }};
}

{% if env.ssl_skip | default(false) %}
# HTTP-only server (cert pending manual install -- ssl_skip is set)
server {
    listen 80;
    server_name {{ env.domain }};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_connect_timeout 300;
    proxy_send_timeout 300;
    proxy_read_timeout 300;

{% if env.backend_only | default(false) %}
    location /api {
        proxy_pass http://backend-{{ env.name }};
    }

    location /health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }

    location / {
        return 200 "BRC Analytics API ({{ env.name }})\n\nAPI Documentation: /api/v1/docs\nHealth: /api/v1/health\n";
        add_header Content-Type text/plain;
    }
{% else %}
    location /api/ {
        alias /opt/brc-analytics-{{ env.name }}/out/api/;
        add_header Access-Control-Allow-Origin $cors_origin always;
        add_header Access-Control-Allow-Methods "GET, OPTIONS" always;
        add_header X-Content-Type-Options "nosniff" always;
        try_files $uri =404;
    }

    location /api/v1 {
        proxy_pass http://backend-{{ env.name }};
    }

    location /ena/ {
        proxy_pass https://www.ebi.ac.uk/ena/;
        proxy_set_header Host www.ebi.ac.uk;
        proxy_ssl_server_name on;
    }

    location /health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }

    location / {
        root /opt/brc-analytics-{{ env.name }}/out;
        try_files $uri $uri.html $uri/ /index.html;
    }
{% endif %}
}
{% else %}
# Redirect HTTP to HTTPS
server {
    listen 80;
    server_name {{ env.domain }}{% if env.domain_aliases is defined %}{% for alias in env.domain_aliases %} {{ alias }}{% endfor %}{% endif %};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://{{ env.domain }}$request_uri;
    }
}

# HTTPS server
server {
    listen 443 ssl http2;
    server_name {{ env.domain }};

    ssl_certificate /etc/letsencrypt/live/{{ env.cert_domain | default(env.domain) }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ env.cert_domain | default(env.domain) }}/privkey.pem;

    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:50m;
    ssl_session_tickets off;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;

    add_header Strict-Transport-Security "max-age=63072000" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;

    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/xml application/json application/javascript application/rss+xml application/atom+xml image/svg+xml;

    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_connect_timeout 300;
    proxy_send_timeout 300;
    proxy_read_timeout 300;

{% if env.backend_only | default(false) %}
    location /api {
        proxy_pass http://backend-{{ env.name }};
    }

    location /health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }

    location / {
        return 200 "BRC Analytics API ({{ env.name }})\n\nAPI Documentation: /api/v1/docs\nHealth: /api/v1/health\n";
        add_header Content-Type text/plain;
    }
{% else %}
    # Static API data files (from the Next.js build output)
    location /api/ {
        alias /opt/brc-analytics-{{ env.name }}/out/api/;
        add_header Access-Control-Allow-Origin $cors_origin always;
        add_header Access-Control-Allow-Methods "GET, OPTIONS" always;
        add_header X-Content-Type-Options "nosniff" always;
        try_files $uri =404;
    }

    # FastAPI proxy
    location /api/v1 {
        proxy_pass http://backend-{{ env.name }};
    }

    # ENA upstream proxy
    location /ena/ {
        proxy_pass https://www.ebi.ac.uk/ena/;
        proxy_set_header Host www.ebi.ac.uk;
        proxy_ssl_server_name on;
    }

    location /health {
        access_log off;
        return 200 "healthy\n";
        add_header Content-Type text/plain;
    }

    # Static frontend
    location / {
        root /opt/brc-analytics-{{ env.name }}/out;
        try_files $uri $uri.html $uri/ /index.html;

        location ~* \.(css|js|jpg|jpeg|png|gif|ico|svg|woff|woff2|ttf|eot)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
            add_header Strict-Transport-Security "max-age=63072000" always;
            add_header X-Content-Type-Options "nosniff" always;
        }

        location ~* \.html$ {
            expires 1h;
            add_header Cache-Control "public";
            add_header Strict-Transport-Security "max-age=63072000" always;
            add_header X-Content-Type-Options "nosniff" always;
            add_header X-Frame-Options "SAMEORIGIN" always;
            add_header X-XSS-Protection "1; mode=block" always;
        }
    }
{% endif %}
}

{% if env.domain_aliases is defined %}
# Redirect alias domains to primary
server {
    listen 443 ssl;
    server_name {{ env.domain_aliases | join(' ') }};
    ssl_certificate /etc/letsencrypt/live/{{ env.cert_domain | default(env.domain) }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ env.cert_domain | default(env.domain) }}/privkey.pem;
    return 301 https://{{ env.domain }}$request_uri;
}
{% endif %}
{% endif %}

{% endfor %}
