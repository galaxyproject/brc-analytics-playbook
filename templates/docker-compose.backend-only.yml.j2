# Docker Compose Override - Backend Only
# Managed by Ansible - do not edit manually
#
# This override disables the frontend service and exposes the backend
# on a specific port for host-level nginx to proxy to.
---
services:
  frontend:
    profiles:
      - disabled
  backend:
    # !override fully replaces the ports list from the base compose file.
    # Without this, Compose merges and the base's "8000:8000" (binding
    # 0.0.0.0:8000) leaks through, causing cross-env port conflicts.
    ports: !override
      - "127.0.0.1:{{ env.backend_port }}:8000"
{% if brc_keycloak_client_id %}
    depends_on:
      brc-app-db:
        condition: service_healthy
  # Persistent user-data store, one per environment. Compose namespaces the
  # service and volume by project (-p brc-analytics-<env>), so staging/beta get
  # isolated databases. Keycloak runs externally, so we add only the database.
  brc-app-db:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: "{{ app_db_name }}"
      POSTGRES_USER: "{{ app_db_user }}"
      POSTGRES_PASSWORD: "{{ app_db_password }}"
    volumes:
      - brc_app_db_data:/var/lib/postgresql/data
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ app_db_user }} -d {{ app_db_name }}"]
      interval: 5s
      timeout: 5s
      retries: 5

volumes:
  brc_app_db_data:
{% endif %}
